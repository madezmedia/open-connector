# open-connector — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git

# ── Access Control ──────────────────────────────────────────
OOMOL_CONNECT_ORIGIN=*

# ── Encryption ───────────────────────────────────────────────
# Generate with: openssl rand -hex 32
OOMOL_CONNECT_ENCRYPTION_KEY=REPLACE_WITH_32BYTE_HEX_KEY

# ── Tokens ──────────────────────────────────────────────────
# Admin token — full access
OOMOL_CONNECT_ADMIN_TOKEN=REPLACE_WITH_ADMIN_TOKEN

# Runtime token — agent-facing, limited scope
OOMOL_CONNECT_RUNTIME_TOKEN=REPLACE_WITH_RUNTIME_TOKEN

# ── Action Filter ────────────────────────────────────────────
# Allow all actions (*), or comma-separated list:
# e.g. google.gmail.send, github.repo.create, openai.chat.completions
OOMOL_CONNECT_ALLOWED_ACTIONS=*

# Block specific actions (comma-separated)
OOMOL_CONNECT_BLOCKED_ACTIONS=

# ── Proxy Filter ─────────────────────────────────────────────
OOMOL_CONNECT_ALLOWED_PROXIES=
OOMOL_CONNECT_BLOCKED_PROXIES=

# ── Fleet Metadata (set by deploy script) ──────────────────
DEPLOY_TIMESTAMP=
DEPLOYED_BY=
